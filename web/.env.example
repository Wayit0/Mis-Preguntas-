# Conexión a Postgres (Azure Postgres Flexible Server, sslmode=require)
DATABASE_URL=postgresql://usuario:password@host:5432/mispreguntas?sslmode=require

# better-auth
BETTER_AUTH_SECRET=cambia-esto-por-un-secreto-aleatorio-largo
BETTER_AUTH_URL=http://localhost:3000

# Anthropic (detección de preguntas con IA)
ANTHROPIC_API_KEY=sk-ant-...

# Azure Blob Storage (imágenes)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
BLOB_CONTAINER=uploads
