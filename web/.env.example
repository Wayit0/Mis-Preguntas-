# Conexión a Postgres (Azure Postgres Flexible Server, sslmode=require)
DATABASE_URL=postgresql://usuario:password@host:5432/mispreguntas?sslmode=require

# better-auth
BETTER_AUTH_SECRET=cambia-esto-por-un-secreto-aleatorio-largo
BETTER_AUTH_URL=http://localhost:3000
# URL base para el cliente (browser). En prod = mismo host público. Si se omite,
# el cliente cae a same-origin (suele bastar).
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Correo transaccional (Resend) — verificación de cuenta y recuperación de
# contraseña. Si RESEND_API_KEY no está, el envío se OMITE con warning (útil en
# local: el enlace igual queda en los logs del server).
RESEND_API_KEY=re_...
EMAIL_FROM=EduBox <no-reply@edubox.cl>

# Login social (OAuth). Cada proveedor se ACTIVA sólo si su par id/secret está
# presente; sin ellos, los botones no aparecen. Redirect URIs a registrar:
#   {BETTER_AUTH_URL}/api/auth/callback/google
#   {BETTER_AUTH_URL}/api/auth/callback/microsoft
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Anthropic (detección de preguntas con IA)
ANTHROPIC_API_KEY=sk-ant-...

# Sólo para pruebas: si se define (p. ej. =1), la detección de preguntas omite
# la llamada real a Anthropic y devuelve un fixture determinista. No usar en prod.
# IMPORT_AI_FAKE=1

# Azure Blob Storage (imágenes)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
BLOB_CONTAINER=uploads
